<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ModifierRendezVous">
    <VBox spacing="10" layoutX="50" layoutY="50">
        <TextField fx:id="date" promptText="Date (YYYY-MM-DD)"/>
        <TextField fx:id="id_patient" promptText="ID Patient"/>
        <ComboBox fx:id="medecinComboBox" promptText="Médecin"/>
        <TextField fx:id="type_consultation" promptText="Type de Consultation"/>
        <Button text="Modifier" onAction="#modifier"/>
    </VBox>
</AnchorPane>