<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.test.TelecommunicationController" spacing="10" padding="10">
    <Label text="Interface de Télécommunication" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <TextField fx:id="roomIdField" promptText="Entrez l'ID de la salle"/>
    <TextField fx:id="userIdentityField" promptText="Entrez votre identité"/>
    <Button text="Créer une salle" onAction="#handleCreateRoom"/>
    <Button text="Rejoindre une salle" onAction="#handleJoinRoom"/>
    <Button text="Terminer la salle" onAction="#handleEndRoom"/>
    <Label fx:id="statusLabel" style="-fx-text-fill: blue;"/>
</VBox>