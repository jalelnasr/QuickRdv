<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.VideoChatControllers" spacing="10">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    <StackPane fx:id="localVideoView" style="-fx-background-color: black;" prefHeight="300" prefWidth="400"/>
    <StackPane fx:id="remoteVideoView" style="-fx-background-color: black;" prefHeight="300" prefWidth="400"/>
    <Button text="Démarrer le Chat Vidéo" onAction="#startVideoChat"/>
    <Button text="Arrêter le Chat Vidéo" onAction="#stopVideoChat"/>
</VBox>