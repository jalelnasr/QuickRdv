<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="rootPane" prefHeight="701.0" prefWidth="959.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AjouterRendezVous">
    <children>
        <TextField fx:id="date" layoutX="118.0" layoutY="105.0" promptText="Date (YYYY-MM-DD)" />
        <TextField fx:id="time" layoutX="118.0" layoutY="150.0" promptText="Heure (HH:mm)" />
        <TextField fx:id="id_patient" layoutX="118.0" layoutY="204.0" promptText="ID Patient (Number Only)" />
        <ComboBox fx:id="medecinComboBox" layoutX="118.0" layoutY="304.0" promptText="Sélectionner un médecin" prefWidth="200.0" />
        <ComboBox fx:id="typeConsultationComboBox" layoutX="118.0" layoutY="402.0" promptText="Type de Consultation" prefWidth="200.0" />
        <Button layoutX="597.0" layoutY="473.0" mnemonicParsing="false" onAction="#reserve" prefHeight="53.0" prefWidth="124.0" text="Réserver" />
        <Button fx:id="btnAfficherRendezVous" text="Afficher Rendez-vous" onAction="#handleAfficherRendezVous" />
    </children>
</AnchorPane>
